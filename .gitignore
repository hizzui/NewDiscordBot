# ==================== TOKENS & CREDENCIAIS ====================
# Arquivo de variáveis de ambiente com tokens, secrets e credenciais
.env
.env.local
.env.*.local

# Cookies e sessões autenticadas
cookies.txt
cookies.json

# ==================== PYTHON ====================
# Cache de bytecode Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Ambientes virtuais
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
