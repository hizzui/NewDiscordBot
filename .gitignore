share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pip
*.pip

# Poetry
poetry.lock

# Pytest
.pytest_cache/
.coverage
htmlcov/

# ==================== ARQUIVOS PESSOAIS & SENSÍVEIS ====================
# Arquivos de cookies (contém sessões)
cookies.txt
cookies.json

# Chaves SSH ou certificados
*.pem
*.key
*.crt

# Arquivos de backup
*.bak
*.backup
*-backup/
*.old
*.tmp

