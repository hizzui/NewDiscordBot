# ==================== ARQUIVOS DE CONFIGURAÇÃO LOCAIS ====================
# Configurações específicas do usuário
config.ini
settings.json
local_config.json

# ==================== SISTEMA ====================
# Node modules (se usar ferramentas Node)
node_modules/

# ==================== MISC ====================
# Arquivos temporários do sistema
*.tmp
.temp/
temp/

# Diretórios de teste
test_results/
.tox/

# ==================== EXCEÇÕES ====================
# Não ignore o arquivo de exemplo
!.env.exemplo
!.env.example

# Exclude large binary artifacts
#  * you can manage your artifacts also with test.guide (https://www.test-guide.info) and reference them via Playbooks
Offline-FIUs
Offline-Models
Offline-SGBDs
*.exe
*.msi
*.zip
*.7z

# Exclude default and custom temporary directories
Backup_*

# Python bytecode and cache files
__pycache__/
*.py[cod]
