# ==================== DISCORD BOT ====================
# Token do bot Discord
# Obtenha em: https://discord.com/developers/applications
DISCORD_TOKEN=seu_token_aqui_nao_compartilhe

# ==================== TWITCH API ====================
# Credenciais para integração com Twitch
# Obtenha em: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=seu_client_id_aqui
TWITCH_CLIENT_SECRET=seu_secret_aqui_nao_compartilhe
TWITCH_TOKEN=seu_token_de_acesso_aqui

# ==================== CONFIGURAÇÕES OPCIONAIS ====================
# Você pode adicionar mais configurações conforme necessário
# Exemplo:
# DATABASE_URL=seu_database_url
# API_KEY=sua_chave_de_api
